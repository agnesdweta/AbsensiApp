<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient"
    android:padding="24dp">

    <!-- MAIN CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="28dp"
        app:cardElevation="14dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center_horizontal">

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="#4F46E5"
                    android:padding="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kembali"
                    android:textColor="#4F46E5"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- ICON -->
            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="#4F46E5"
                android:layout_marginBottom="10dp"/>

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABSENSI KARYAWAN"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Silakan pilih jenis absensi"
                android:textSize="13sp"
                android:textColor="#777"
                android:layout_marginBottom="20dp"/>

            <!-- STATUS -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS: BELUM ABSEN"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="#B91C1C"
                android:layout_marginBottom="10dp"/>

            <!-- JAM -->
            <TextView
                android:id="@+id/tvJamMasuk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jam: --:--:--"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#444"
                android:layout_marginBottom="24dp"/>

            <!-- BUTTON ABSEN MASUK -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMasuk"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ABSEN MASUK"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4F46E5"
                app:cornerRadius="16dp"
                android:layout_marginBottom="14dp"/>

            <!-- BUTTON ABSEN KELUAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKeluar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ABSEN KELUAR"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9333EA"
                app:cornerRadius="16dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>