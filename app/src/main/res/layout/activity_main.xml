<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="30dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center_horizontal">

            <!-- ICON -->
            <ImageView
                android:layout_width="85dp"
                android:layout_height="85dp"
                android:src="@android:drawable/ic_menu_view"
                app:tint="#4F46E5"
                android:layout_marginBottom="12dp"/>

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard Karyawan"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#111827"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih menu yang ingin digunakan"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="24dp"/>

            <!-- ABSENSI -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAbsen"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="#4F46E5"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Absensi"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"
                        android:textColor="#111827"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- CUTI -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCuti"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="#7C3AED"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cuti"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"
                        android:textColor="#111827"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- RIWAYAT CUTI -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRiwayatCuti"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="#F59E0B"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Riwayat Cuti"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"
                        android:textColor="#111827"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- PROFIL -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfil"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="18dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@android:drawable/ic_menu_manage"
                        app:tint="#2563EB"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profil"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"
                        android:textColor="#111827"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- LOGOUT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogout"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                app:cardCornerRadius="18dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FECACA"
                app:cardBackgroundColor="#FEF2F2">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">
                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@android:drawable/ic_lock_power_off"
                        app:tint="#DC2626" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logout"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"
                        android:textColor="#DC2626"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>